{
  "expo": {
    "name": "DocuRx MR",
    "slug": "docurx-mr",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFF6FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.docurx.mr"
    },
    "android": {
      "package": "com.docurx.mr",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow DocuRx MR to access the microphone for the live demo."
        }
      ]
    ],
    "owner": "utkarsh7477",
    "extra": {
      "eas": {},
      "apiUrl": "https://doctortranscription-production.up.railway.app"
    }
  }
}
